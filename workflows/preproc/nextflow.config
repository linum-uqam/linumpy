manifest {
    nextflowVersion = '>= 23.10'
}

params {
    // Input/Output
    input = ""
    output = "output"
    
    // Processing options
    processes = 1  // Maximum number of python processes per nextflow process
    use_old_folder_structure = false  // Use the old folder structure where tiles are not stored in subfolders based on their Z
    
    // CPU core management
    // Master toggle: set to false to disable all CPU limiting (use all available cores)
    enable_cpu_limits = true
    // Option 1: Set explicit max cores (takes precedence)
    max_cpus = null  // null = auto-detect, or set explicit number
    // Option 2: Reserve cores for overhead
    reserved_cpus = 2  // Number of cores to keep free for system overhead

    // Mosaic grid parameters
    axial_resolution = 1.36  // Axial resolution of imaging system in microns
    resolution = -1  // Resolution of mosaic grid. Defaults to full resolution (-1)
    sharding_factor = 4  // There will be N x N chunks per shard
    
    // Correction options
    fix_galvo_shift = true  // Should be true for new data, else false
    fix_camera_shift = false  // Should be set to false for new data, else true
    preprocess = false  // Apply rotation/flip preprocessing (true for legacy data, false for new acquisitions)
    galvo_confidence_threshold = 0.6  // Minimum confidence (0-1) to apply galvo fix. Higher = more conservative
    
    // Slice configuration options
    generate_slice_config = true  // Generate slice_config.csv for controlling which slices to use
    exclude_first_slices = 1  // Exclude first N slices as calibration (default: 1)
    detect_galvo = false  // Run galvo shift detection and include results in slice_config.csv
    
    // Quality assessment options
    assess_quality = false  // Run quality assessment on mosaic grids and update slice_config
    min_quality_score = 0.2  // Minimum quality score to include slice (0-1). 0 = report only
    quality_sample_depth = 10  // Number of z-planes to sample per slice for quality assessment

    // Optional outputs
    generate_previews = false  // Generate orthogonal view previews of mosaic grids

    // GPU acceleration options
    use_gpu = true  // Enable GPU acceleration if available (automatic fallback to CPU)
}

// Calculate available CPUs based on configuration
def getAvailableCpus() {
    int totalCpus = Runtime.runtime.availableProcessors()
    // If CPU limits are disabled, return all CPUs
    if (params.enable_cpu_limits == false) {
        return totalCpus
    }
    if (params.max_cpus != null && params.max_cpus > 0) {
        int maxCpus = params.max_cpus as int
        return Math.min(maxCpus, totalCpus)
    }
    int reserved = (params.reserved_cpus ?: 2) as int
    return Math.max(1, totalCpus - reserved)
}

process {
    publishDir = {"$params.output"}
    scratch = true
    stageInMode='symlink'
    stageOutMode='rsync'
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
    maxRetries = 3
    afterScript='sleep 1'

    // Set CPU limiting environment variables for Python scripts
    beforeScript = {
        // If CPU limits are disabled, don't set any limiting environment variables
        if (params.enable_cpu_limits == false) {
            return ""
        }

        int maxCpus = getAvailableCpus() as int
        int numProcesses = Math.max(1, (params.processes ?: 1) as int)
        int threadsPerProcess = Math.max(1, (int)(maxCpus / numProcesses))

        def envVars = []
        // Always set LINUMPY variables so Python scripts know about limits
        if (params.max_cpus != null && params.max_cpus > 0) {
            envVars << "export LINUMPY_MAX_CPUS=${params.max_cpus as int}"
        } else {
            // Always set reserved CPUs (default is 2)
            envVars << "export LINUMPY_RESERVED_CPUS=${(params.reserved_cpus ?: 2) as int}"
        }

        // Set threading environment variables unconditionally
        // These MUST be set before Python imports numpy/scipy
        envVars << "export OMP_NUM_THREADS=${threadsPerProcess}"
        envVars << "export MKL_NUM_THREADS=${threadsPerProcess}"
        envVars << "export OPENBLAS_NUM_THREADS=${threadsPerProcess}"
        envVars << "export VECLIB_MAXIMUM_THREADS=${threadsPerProcess}"
        envVars << "export NUMEXPR_NUM_THREADS=${threadsPerProcess}"
        envVars << "export NUMBA_NUM_THREADS=${threadsPerProcess}"
        envVars << "export ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS=${threadsPerProcess}"
        // JAX/XLA thread limiting (used by BaSiCPy in fix_illumination)
        envVars << "export XLA_FLAGS='--xla_cpu_multi_thread_eigen=false intra_op_parallelism_threads=${threadsPerProcess}'"

        return envVars.join('\n')
    }
}

apptainer {
    autoMounts = true
    enabled = true
}

profiles {
    calliste {
        apptainer {
            cacheDir='/scratchCalliste/apptainer/cache'
            libraryDir='/scratchCalliste/apptainer/library'
            autoMounts = true
            enabled = true
            runOptions = '-B /mnt/apptainer_tmp:/tmp'
        }
        docker {
            temp = '/mnt/apptainer_tmp'
        }
        process {
            withName: "create_mosaic_grid" { 
                scratch = false
            }
        }
    }
}
