manifest {
    nextflowVersion = '>= 23.10'
}

params {
    // =========================================================================
    // INPUT/OUTPUT
    // =========================================================================
    input = "."
    output = "."
    shifts_xy = ""  // Auto-detected as {input}/shifts_xy.csv if empty
    slice_config = "" // Auto-detected as {input}/slice_config.csv if empty
    subject_name = ""  // Auto-extracted from input path if empty

    // =========================================================================
    // RESOLUTION & BASIC SETTINGS
    // =========================================================================
    resolution = 10  // Target resolution in µm/pixel (-1 to skip resampling)
    clip_percentile_upper = 99.9  // Upper percentile for intensity clipping

    // =========================================================================
    // PREPROCESSING STEPS (enable/disable)
    // =========================================================================
    fix_curvature_enabled = true   // Detect and compensate focal curvature
    fix_illum_enabled = true       // Fix illumination using BaSiC algorithm
    crop_interface_out_depth = 600 // Maximum depth after cropping (µm)

    // =========================================================================
    // REGISTRATION
    // =========================================================================
    // Pairwise registration: aligns consecutive slices
    registration_transform = 'euler'  // 'translation', 'euler' (recommended for angled), 'affine'
    registration_metric = 'MI'        // 'CC', 'MSE', 'MI' (robust to contrast changes)
    registration_max_translation = 300.0     // Max translation in pixels (oblique acquisition)
    registration_max_rotation = 35.0         // Max rotation in degrees (oblique acquisition)
    moving_slice_first_index = 8             // Z-index offset in moving volume
    registration_slicing_interval_mm = 0.200 // Physical slice spacing in mm
    registration_allowed_drifting_mm = 0.350 // Z-drift tolerance in mm (oblique acquisition)
    registration_z_bias = 0.25               // Expected-z bias weight for z-matching


    // Mask creation for registration
    create_registration_masks = true
    registration_mask_mode = 'multiply' // 'multiply' (pre-multiply images, recommended), 'sitk' (SimpleITK mask params), 'none' (ignore)
    mask_smoothing_sigma = 5.0  // Gaussian sigma in µm
    selem_radius = 1            // Morphological structuring element radius (pixels)
    min_size = 100              // Minimum mask component size (pixels)
    mask_normalize = true       // Normalize image before masking
    mask_fill_holes = 'slicewise' // 'none', '3d', 'slicewise' (fills holes in all 3 axes - best for registration)

    // Shift outlier filtering (for bring_to_common_space)
    filter_shift_outliers = true    // Enable IQR-based outlier filtering
    outlier_method = 'iqr'          // 'iqr', 'local', 'median', 'clamp', 'zero'
    outlier_iqr_multiplier = 1.0    // IQR multiplier for outlier detection
    max_shift_mm = 0.6              // Max shift threshold (only if method != 'iqr')
    common_space_max_step_mm = 0.7  // Max per-step shift in mm (0 disables)
    common_space_step_window = 3    // Neighbor window for step outlier replacement
    common_space_step_method = 'local_median' // 'local_median' or 'clamp'
    common_space_excluded_slice_mode = 'local_median' // 'keep', 'local_median', 'median', 'zero'
    common_space_excluded_slice_window = 2

    // =========================================================================
    // STACKING & OUTPUT
    // =========================================================================
    stack_blend_enabled = false           // Blend overlapping regions
    stack_max_overlap = -1                // Max overlap voxels (-1 = all)
    stack_no_accumulate_transforms = true // Slices are already in common space

    // Pyramid resolutions (µm) - only resolutions >= base resolution are included
    pyramid_resolutions = [10, 25, 50, 100]
    pyramid_n_levels = null        // Set to int for traditional 2x downsampling
    pyramid_make_isotropic = true  // Resample to isotropic voxels

    // =========================================================================
    // MISSING SLICE INTERPOLATION
    // =========================================================================
    interpolate_missing_slices = false        // Enable gap interpolation
    interpolation_method = 'registration'     // 'registration', 'average', 'weighted'
    interpolation_blend_method = 'gaussian'   // 'gaussian' (feathered, recommended), 'linear' (50/50)
    interpolation_registration_metric = 'MSE'
    interpolation_max_iterations = 1000
    interpolation_use_degraded = true         // Use degraded slice data if available
    interpolation_min_quality = 0.2           // Minimum quality score (0-1)

    // =========================================================================
    // COMPUTE RESOURCES
    // =========================================================================
    use_gpu = true      // Enable GPU acceleration (auto-fallback to CPU)
    processes = 12      // Python processes per Nextflow process (48 cores / 4 = 12)

    // CPU limiting
    enable_cpu_limits = true
    max_cpus = 44       // Reserve 4 cores for system overhead on 48-core server
    reserved_cpus = 4   // Cores to reserve for system overhead

    // =========================================================================
    // DEBUGGING & PREVIEWS
    // =========================================================================
    debug_slices = ""            // Comma-separated slice IDs or ranges (e.g., "25,26" or "25-29")
    analyze_shifts = false       // Generate shifts analysis report
    mask_preview = false         // Generate mask preview images

    // =========================================================================
    // DIAGNOSTIC MODE (for troubleshooting reconstruction artifacts)
    // =========================================================================
    // Master switch: enables ALL diagnostic analyses when true
    // Use for troubleshooting edge mismatches, overhangs, and alignment issues
    // in obliquely-mounted samples (e.g., 45° between standard planes)
    diagnostic_mode = false

    // Granular control (only needed if diagnostic_mode=false and you want specific analyses)
    analyze_rotation_drift = false       // Analyze cumulative rotation between slices (mosaic-level)
    analyze_tile_dilation = false        // Compare motor vs registration tile positions (tile-level)
    motor_only_stitch = false            // Create stitched slices using only motor positions

    // Diagnostic parameters
    motor_only_overlap = 0.2             // Expected tile overlap fraction for motor-only stitch
    diagnostic_rotation_threshold = 2.0  // Flag rotations above this threshold (degrees)
    common_space_preview = false // Generate common space alignment previews
    interpolation_preview = false // Generate interpolation previews
    generate_report = true       // Generate quality report
    report_verbose = false       // Include detailed metrics in report

    // Annotated preview settings
    annotated_label_every = 1    // Label every Nth slice in annotated preview (1=all)
    annotated_show_lines = false // Show slice boundary lines in annotated preview
}

// =========================================================================
// CPU CONFIGURATION (internal)
// =========================================================================
def getAvailableCpus() {
    int totalCpus = Runtime.runtime.availableProcessors()
    if (params.enable_cpu_limits == false) return totalCpus
    if (params.max_cpus != null && params.max_cpus > 0) {
        return Math.min(params.max_cpus as int, totalCpus)
    }
    return Math.max(1, totalCpus - (params.reserved_cpus ?: 2) as int)
}

// =========================================================================
// PROCESS CONFIGURATION
// =========================================================================
process {
    publishDir = {"$params.output/$slice_id/$task.process"}
    scratch = true
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    maxRetries = 2
    stageInMode = 'symlink'
    stageOutMode = 'rsync'
    afterScript = 'sleep 1'

    // Thread limiting for Python scripts
    beforeScript = {
        if (params.enable_cpu_limits == false) return ""

        int maxCpus = getAvailableCpus() as int
        int numProcesses = Math.max(1, (params.processes ?: 1) as int)
        int threadsPerProcess = Math.max(1, (int)(maxCpus / numProcesses))

        def envVars = []
        if (params.max_cpus != null && params.max_cpus > 0) {
            envVars << "export LINUMPY_MAX_CPUS=${params.max_cpus as int}"
        } else {
            envVars << "export LINUMPY_RESERVED_CPUS=${(params.reserved_cpus ?: 2) as int}"
        }

        // Thread limiting environment variables
        envVars << "export OMP_NUM_THREADS=${threadsPerProcess}"
        envVars << "export MKL_NUM_THREADS=${threadsPerProcess}"
        envVars << "export OPENBLAS_NUM_THREADS=${threadsPerProcess}"
        envVars << "export VECLIB_MAXIMUM_THREADS=${threadsPerProcess}"
        envVars << "export NUMEXPR_NUM_THREADS=${threadsPerProcess}"
        envVars << "export NUMBA_NUM_THREADS=${threadsPerProcess}"
        envVars << "export ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS=${threadsPerProcess}"
        envVars << "export XLA_FLAGS='--xla_cpu_multi_thread_eigen=false intra_op_parallelism_threads=${threadsPerProcess}'"

        return envVars.join('\n')
    }

    withName: "resample_mosaic_grid" {
        scratch = false
        // Allow parallel mask creation on GPU
        maxForks = params.use_gpu ? 4 : null
    }

    withName: "fix_illumination" {
        // Limit to 1 parallel instance - BaSiCPy/JAX is memory-intensive
        maxForks = params.use_gpu ? 1 : null
        // Don't set CUDA_VISIBLE_DEVICES - let linumpy.gpu auto-select GPU with most free memory
    }

    withName: "create_registration_masks" {
        // Allow parallel mask creation on GPU
        maxForks = params.use_gpu ? 4 : null
    }

    withName: "normalize" {
        // Allow parallel normalization on GPU
        maxForks = params.use_gpu ? 4 : null
    }

    withName: "estimate_xy_transformation" {
        // Allow parallel XY estimation on GPU
        maxForks = params.use_gpu ? 4 : null
    }
}

// =========================================================================
// CONTAINER CONFIGURATION
// =========================================================================
apptainer {
    autoMounts = true
    enabled = true
}

// =========================================================================
// CLUSTER PROFILES
// =========================================================================
profiles {
    calliste {
        apptainer {
            cacheDir = '/scratchCalliste/apptainer/cache'
            libraryDir = '/scratchCalliste/apptainer/library'
            autoMounts = true
            enabled = true
            runOptions = '-B /mnt/apptainer_tmp:/tmp'
        }
        docker {
            temp = '/mnt/apptainer_tmp'
        }
        process {
            withName: "resample_mosaic_grid" {
                scratch = false
                maxForks = 4
            }
        }
    }
}
