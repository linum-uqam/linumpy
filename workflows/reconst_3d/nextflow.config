manifest {
    nextflowVersion = '>= 23.10'
}

params {
    // =========================================================================
    // INPUT/OUTPUT
    // =========================================================================
    input = "."                // Directory containing mosaic_grid*.ome.zarr files
    output = "."               // Output directory for all pipeline results
    shifts_xy = ""             // Path to shifts CSV (default: {input}/shifts_xy.csv)
    slice_config = ""          // Path to slice config CSV (default: {input}/slice_config.csv)
    subject_name = ""          // Subject identifier (default: auto-extracted from path)

    // =========================================================================
    // RESOLUTION & BASIC SETTINGS
    // =========================================================================
    resolution = 10            // Target resolution in µm/pixel (set to -1 to skip resampling)
    clip_percentile_upper = 99.9  // Upper percentile for intensity clipping (0-100)

    // =========================================================================
    // PREPROCESSING STEPS
    // =========================================================================
    fix_curvature_enabled = false    // Detect and compensate focal curvature artifacts
    fix_illum_enabled = true        // Fix illumination inhomogeneity (BaSiC algorithm)
    crop_interface_out_depth = 600  // Maximum tissue depth to retain after cropping (µm)

    // Normalization settings
    normalize_min_contrast = 0.1    // Min contrast fraction to prevent over-amplification
                                    // of weak/bad slices (0-1, 0.1 = 10% of global max)

    // =========================================================================
    // TILE STITCHING
    // =========================================================================
    // Controls how tiles within each slice are stitched together.
    // Motor positions are more precise than image-based registration.
    use_motor_positions_for_stitching = true  // Use motor positions (recommended)
    stitch_overlap_fraction = 0.2             // Expected tile overlap fraction (0-1)
                                              // This should match your acquisition settings
    stitch_blending_method = 'diffusion'      // Blending method: 'none', 'average', 'diffusion'
    use_refined_stitching = true              // Use registration to refine blend transitions
                                              // Helps reduce visible tile seams
    max_blend_refinement_px = 10              // Max sub-pixel refinement for blending (pixels)

    // =========================================================================
    // REGISTRATION (refinement on top of motor positions)
    // =========================================================================
    // Pairwise registration computes small corrections (rotation, sub-pixel shift)
    // The main XY alignment comes from motor positions (shifts_xy.csv)

    registration_transform = 'euler'         // 'translation' (XY only) or 'euler' (XY + rotation)
    registration_max_translation = 20.0      // Max refinement translation (pixels) - keep small!
    registration_max_rotation = 5.0          // Max rotation correction (degrees)
    moving_slice_first_index = 4             // Starting Z-index in moving volume
    registration_slicing_interval_mm = 0.200 // Physical slice thickness (mm)
    registration_allowed_drifting_mm = 0.100 // Z-search range (mm)

    // Registration mask settings
    create_registration_masks = true         // Create tissue masks for registration
    mask_smoothing_sigma = 5.0               // Gaussian smoothing sigma (µm)
    selem_radius = 1                         // Morphological element radius (pixels)
    min_size = 100                           // Minimum mask component size (pixels)
    mask_normalize = true                    // Normalize intensities before masking
    mask_fill_holes = 'slicewise'            // Hole filling: 'none', '3d', 'slicewise'

    // Shift outlier filtering (applied during common space alignment)
    filter_shift_outliers = true             // Enable outlier filtering
    outlier_method = 'iqr'                   // Method: 'iqr', 'local', 'median', 'clamp', 'zero'
    outlier_iqr_multiplier = 1.0             // IQR multiplier for outlier detection
    max_shift_mm = 0.6                       // Maximum allowed shift (mm)
    common_space_max_step_mm = 0.7           // Maximum per-step shift (mm, 0 = disabled)
    common_space_step_window = 3             // Window size for step outlier detection
    common_space_step_method = 'local_median'       // Step correction: 'local_median', 'clamp'
    common_space_excluded_slice_mode = 'local_median' // Excluded slice handling
    common_space_excluded_slice_window = 2


    // =========================================================================
    // STACKING & OUTPUT
    // =========================================================================
    // Choose stacking method:
    //   'motor' - Use motor positions (shifts_xy.csv) for XY, correlation for Z (recommended)
    //   'registration' - Use pairwise registration for both XY and Z (traditional)
    stacking_method = 'motor'             // 'motor' (recommended) or 'registration'
    use_expected_z_overlap = true         // Use expected Z-overlap instead of correlation
                                          // Set to true when correlation-based matching is unreliable
    apply_rotation_only = true            // Apply only rotation from registration, not translation
                                          // Set to true when motor positions are trusted for XY
    max_rotation_deg = 1.0                // Maximum rotation per slice (degrees)
                                          // Larger rotations are clamped to prevent registration
                                          // errors from causing cumulative drift

    stack_blend_enabled = false       // Enable blending of overlapping regions
    stack_max_overlap = -1            // Maximum overlap in voxels (-1 = unlimited)
    stack_no_accumulate_transforms = true  // Skip transform accumulation (slices in common space)

    // Multi-resolution pyramid settings
    pyramid_resolutions = [10, 25, 50, 100]  // Resolution levels (µm), must be >= base
    pyramid_n_levels = null                   // Fixed level count (overrides resolutions)
    pyramid_make_isotropic = true             // Resample to isotropic voxel spacing

    // =========================================================================
    // MISSING SLICE INTERPOLATION
    // =========================================================================
    interpolate_missing_slices = false         // Enable interpolation for single-slice gaps
    interpolation_method = 'registration'      // Method: 'registration', 'average', 'weighted'
    interpolation_blend_method = 'gaussian'    // Blending: 'gaussian' (feathered), 'linear'
    interpolation_registration_metric = 'MSE'  // Registration metric for interpolation
    interpolation_max_iterations = 1000        // Maximum registration iterations
    interpolation_use_degraded = true          // Use degraded slice data when available
    interpolation_min_quality = 0.2            // Minimum quality score threshold (0-1)

    // =========================================================================
    // COMPUTE RESOURCES
    // =========================================================================
    use_gpu = true           // Enable GPU acceleration (auto-fallback to CPU if unavailable)
    processes = 12           // Number of parallel Python processes per Nextflow task

    // CPU resource management
    enable_cpu_limits = true // Enable CPU limiting
    max_cpus = 44            // Maximum CPUs to use (0 = no limit)
    reserved_cpus = 4        // CPUs reserved for system overhead

    // =========================================================================
    // DEBUGGING & PREVIEWS
    // =========================================================================
    debug_slices = ""            // Comma-separated slice IDs or ranges (e.g., "25,26" or "25-29")
    analyze_shifts = false       // Generate shifts analysis report
    mask_preview = false         // Generate mask preview images

    // =========================================================================
    // DIAGNOSTIC MODE
    // =========================================================================
    // Enable for troubleshooting reconstruction artifacts (edge mismatches,
    // overhangs, alignment issues) in obliquely-mounted samples.
    diagnostic_mode = false              // Master switch: enables all diagnostic analyses

    // Individual diagnostic analyses (used when diagnostic_mode=false)
    analyze_rotation_drift = false       // Analyze cumulative rotation between slices
    analyze_tile_dilation = false        // Analyze tile position refinements for dilation
                                         // Note: Only useful when use_refined_stitching=true
    motor_only_stitch = false            // Create stitched slices using motor positions only
    motor_only_stack = false             // Create 3D stack using motor positions only (no pairwise reg)
    compare_stitching = false            // Compare motor-only vs refined stitching

    // Diagnostic parameters
    motor_only_overlap = 0.2             // Expected tile overlap fraction (0-1)
    motor_only_stitch_blending = 'diffusion'  // Blending for motor_only_stitch: 'none', 'average', 'diffusion'
    motor_only_stack_blending = 'none'   // Blending for motor_only_stack: 'none', 'average', 'max', 'feather'
    diagnostic_rotation_threshold = 2.0  // Rotation warning threshold (degrees)

    // Refined stitching parameters (for blending comparison)
    max_blend_refinement_px = 10.0       // Maximum registration refinement for blending (pixels)
    save_refinement_data = false         // Save registration refinement data as JSON
    comparison_tile_step = 60            // Tile step for seam detection in comparison

    // Preview generation
    stitch_preview = true                // Generate stitched slice previews
    common_space_preview = false         // Generate common space alignment previews
    interpolation_preview = false        // Generate interpolation previews
    generate_report = true               // Generate HTML quality report
    report_verbose = false               // Include detailed metrics in report

    // Annotated preview settings
    annotated_label_every = 1            // Label every Nth slice (1 = all slices)
    annotated_show_lines = false         // Show slice boundary lines
}

// =========================================================================
// CPU CONFIGURATION
// =========================================================================
def getAvailableCpus() {
    int totalCpus = Runtime.runtime.availableProcessors()
    if (params.enable_cpu_limits == false) return totalCpus
    if (params.max_cpus != null && params.max_cpus > 0) {
        return Math.min(params.max_cpus as int, totalCpus)
    }
    return Math.max(1, totalCpus - (params.reserved_cpus ?: 2) as int)
}

// =========================================================================
// PROCESS CONFIGURATION
// =========================================================================
process {
    publishDir = {"$params.output/$slice_id/$task.process"}
    scratch = true
    errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    maxRetries = 2
    stageInMode = 'symlink'
    stageOutMode = 'rsync'
    afterScript = 'sleep 1'

    // Thread limiting for Python scripts
    beforeScript = {
        if (params.enable_cpu_limits == false) return ""

        int maxCpus = getAvailableCpus() as int
        int numProcesses = Math.max(1, (params.processes ?: 1) as int)
        int threadsPerProcess = Math.max(1, (int)(maxCpus / numProcesses))

        def envVars = []
        if (params.max_cpus != null && params.max_cpus > 0) {
            envVars << "export LINUMPY_MAX_CPUS=${params.max_cpus as int}"
        } else {
            envVars << "export LINUMPY_RESERVED_CPUS=${(params.reserved_cpus ?: 2) as int}"
        }

        // Thread limiting environment variables
        envVars << "export OMP_NUM_THREADS=${threadsPerProcess}"
        envVars << "export MKL_NUM_THREADS=${threadsPerProcess}"
        envVars << "export OPENBLAS_NUM_THREADS=${threadsPerProcess}"
        envVars << "export VECLIB_MAXIMUM_THREADS=${threadsPerProcess}"
        envVars << "export NUMEXPR_NUM_THREADS=${threadsPerProcess}"
        envVars << "export NUMBA_NUM_THREADS=${threadsPerProcess}"
        envVars << "export ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS=${threadsPerProcess}"
        envVars << "export XLA_FLAGS='--xla_cpu_multi_thread_eigen=false intra_op_parallelism_threads=${threadsPerProcess}'"

        return envVars.join('\n')
    }

    withName: "resample_mosaic_grid" {
        scratch = false
        // Allow parallel mask creation on GPU
        maxForks = params.use_gpu ? 4 : null
    }

    withName: "fix_illumination" {
        // Limit to 1 parallel instance - BaSiCPy/JAX is memory-intensive
        maxForks = params.use_gpu ? 1 : null
        // Don't set CUDA_VISIBLE_DEVICES - let linumpy.gpu auto-select GPU with most free memory
    }

    withName: "create_registration_masks" {
        // Allow parallel mask creation on GPU
        maxForks = params.use_gpu ? 4 : null
    }

    withName: "normalize" {
        // Allow parallel normalization on GPU
        maxForks = params.use_gpu ? 4 : null
    }

    withName: "estimate_xy_transformation" {
        // Allow parallel XY estimation on GPU
        maxForks = params.use_gpu ? 4 : null
    }
}

// =========================================================================
// CONTAINER CONFIGURATION
// =========================================================================
apptainer {
    autoMounts = true
    enabled = true
}

// =========================================================================
// CLUSTER PROFILES
// =========================================================================
profiles {
    calliste {
        apptainer {
            cacheDir = '/scratchCalliste/apptainer/cache'
            libraryDir = '/scratchCalliste/apptainer/library'
            autoMounts = true
            enabled = true
            runOptions = '-B /mnt/apptainer_tmp:/tmp'
        }
        docker {
            temp = '/mnt/apptainer_tmp'
        }
        process {
            withName: "resample_mosaic_grid" {
                scratch = false
                maxForks = 4
            }
        }
    }
}
